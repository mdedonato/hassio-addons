{
  "name": "Cummins Generator Bridge",
  "version": "1.5.0",
  "init": false,
  "slug": "cummins_generator",
  "description": "Connects Cummins Generator to MQTT",
  "arch": ["aarch64", "amd64"],
  "startup": "services",
  "boot": "auto",
  "options": {"mqtt_server": "",
              "mqtt_port": 1883,
              "mqtt_username": "mqttuser",
              "mqtt_password": "mqttuser",
              "generator_address" : "192.168.1.6",
              "username" : "admin",
              "password" : "cummins",
              "time_sync_min" : 10,
              "mqtt_prefix" : "cummins/",
              "device_name" : "Cummins Generator",
              "unique_id" : "cummins",
              "discovery_prefix" : "homeassistant",
              "log_level" : "",
              "timezone" : "America/New_York",
              "poll_interval_sec" : 15,
              "log_refresh_min" : 60
              },
  "schema": {"mqtt_server": "str?",
              "mqtt_port": "int?",
              "mqtt_username": "str?",
              "mqtt_password": "str?",
              "generator_address" : "str?",
              "username" : "str?",
              "password" : "str?",
              "time_sync_min" : "int?",
              "mqtt_prefix" : "str?",
              "device_name" : "str?",
              "unique_id" : "str?",
              "discovery_prefix" : "str?",
              "log_level" : "str?",
              "timezone" : "str?",
              "poll_interval_sec" : "int?",
              "log_refresh_min" : "int?"
            },
  "map": ["config:rw"]
}
